generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Merchant {
  id               String   @id @default(uuid())
  shopDomain       String   @unique @map("shop_domain")
  shopifyStoreId   String?  @map("shopify_store_id")
  accessToken      String?  @map("access_token")
  storeName        String?  @map("store_name")
  email            String?
  plan             String   @default("free")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  orders           Order[]
  customers        CustomerProfile[]
  analyticsEvents  AnalyticsEvent[]

  otpVerifications OtpVerification[]
  paymentSettings  PaymentSettings?
  widgetSettings   WidgetSettings?
  discounts        Discount[]

  @@map("merchants")
}

model Order {
  id                  String   @id @default(uuid())
  merchantId          String   @map("merchant_id")
  shopifyOrderId      String?  @map("shopify_order_id")
  shopifyDraftOrderId String?  @map("shopify_draft_order_id")
  
  customerName        String?  @map("customer_name")
  customerPhone       String?  @map("customer_phone")
  customerEmail       String?  @map("customer_email")
  
  address             String?
  city                String?
  state               String?
  pincode             String?
  
  productTitle        String?  @map("product_title")
  variantId           String?  @map("variant_id")
  quantity            Int      @default(1)
  price               Float    @default(0)
  total               Float    @default(0)
  
  paymentMethod       String?  @map("payment_method") // COD, Prepaid
  paymentId           String?  @map("payment_id") // Razorpay transaction ID
  
  prepaidDiscount     Float    @default(0) @map("prepaid_discount")

  verificationStatus  String?  @map("verification_status") // Pending, Verified
  orderStatus         String?  @map("order_status") // Pending, Synced, Failed
  
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  merchant            Merchant @relation(fields: [merchantId], references: [id])

  @@map("orders")
}

model CustomerProfile {
  id                 String   @id @default(uuid())
  merchantId         String   @map("merchant_id")
  
  phone              String?
  name               String?
  email              String?
  
  address            String?
  city               String?
  state              String?
  pincode            String?
  
  verificationStatus String?  @map("verification_status")
  lastOrderAt        DateTime? @map("last_order_at")
  
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  merchant           Merchant @relation(fields: [merchantId], references: [id])

  @@map("customer_profiles")
}

model AnalyticsEvent {
  id          String   @id @default(uuid())
  merchantId  String   @map("merchant_id")
  sessionId   String?  @map("session_id")
  eventName   String   @map("event_name")
  
  createdAt   DateTime @default(now()) @map("created_at")

  merchant    Merchant @relation(fields: [merchantId], references: [id])

  @@map("analytics_events")
}



model OtpVerification {
  id         String   @id @default(uuid())
  merchantId String   @map("merchant_id")
  phone      String
  code       String
  expiresAt  DateTime @map("expires_at")
  verified   Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")

  merchant   Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@map("otp_verifications")
}

model PaymentSettings {
  id                  String   @id @default(uuid())
  merchantId          String   @unique @map("merchant_id")
  
  // Gateways
  razorpayKeyId       String?  @map("razorpay_key_id")
  razorpayKeySecret   String?  @map("razorpay_key_secret")
  cashfreeAppId       String?  @map("cashfree_app_id")
  cashfreeSecretKey   String?  @map("cashfree_secret_key")
  payuMerchantKey     String?  @map("payu_merchant_key")
  payuMerchantSalt    String?  @map("payu_merchant_salt")

  // Prepaid Discounts
  isPrepaidDiscountEnabled Boolean @default(false) @map("is_prepaid_discount_enabled")
  prepaidDiscountType      String  @default("percentage") // percentage, flat
  prepaidDiscountValue     Float   @default(0) @map("prepaid_discount_value")

  // Partial COD
  isPartialCodEnabled      Boolean @default(false) @map("is_partial_cod_enabled")
  partialCodAmount         Float   @default(0) @map("partial_cod_amount")
  
  // Standard COD
  codFeeAmount             Float   @default(69) @map("cod_fee_amount")

  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  merchant            Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@map("payment_settings")
}

model WidgetSettings {
  id                  String   @id @default(uuid())
  merchantId          String   @unique @map("merchant_id")
  
  primaryColor        String   @default("#111827") @map("primary_color")
  brandLogoUrl        String?  @map("brand_logo_url")
  
  preLoginBannerText  String?  @map("pre_login_banner_text")
  preLoginBannerBg    String?  @default("#000000") @map("pre_login_banner_bg")
  preLoginBannerColor String?  @default("#ffffff") @map("pre_login_banner_color")
  
  postLoginBannerText String?  @map("post_login_banner_text")
  postLoginBannerBg   String?  @default("#000000") @map("post_login_banner_bg")
  postLoginBannerColor String? @default("#ffffff") @map("post_login_banner_color")
  
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  merchant            Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@map("widget_settings")
}

model Discount {
  id              String   @id @default(uuid())
  merchantId      String   @map("merchant_id")
  code            String
  title           String?
  description     String?
  type            String   @default("percentage") // percentage, flat
  value           Float
  isAuto          Boolean  @default(false) @map("is_auto")
  canCombine      Boolean  @default(false) @map("can_combine")
  minItems        Int      @default(0) @map("min_items")
  minCartValue    Float    @default(0) @map("min_cart_value")
  maxDiscount     Float?   @map("max_discount")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  merchant        Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@map("discounts")
}

